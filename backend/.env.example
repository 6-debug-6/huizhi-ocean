# ==================== 使用说明 ====================
# 复制此文件为 .env：cp .env.example .env
# 然后编辑 .env 填入实际的 API Key
# .env 已被 .gitignore 排除，不会提交到 Git

# ==================== 应用基础配置 ====================
APP_NAME=汇智海洋 - 设备检修知识检索与作业系统
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite+aiosqlite:///./data/app_v2.db

# ==================== ChromaDB 向量数据库 ====================
CHROMA_PERSIST_DIR=./data/chroma

# ==================== 文件存储 ====================
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ==================== 大模型 API Key ====================
# DeepSeek（文本对话）：https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# 千问 VL（视觉分析）：https://dashscope.aliyun.com
QWEN_API_KEY=your-qwen-api-key
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-max

# ==================== Embedding 向量化模型 ====================
EMBEDDING_PROVIDER=api
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# ==================== CORS 跨域 ====================
CORS_ORIGINS=["*"]
